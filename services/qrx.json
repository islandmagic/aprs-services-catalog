{
  "id": "qrx",
  "kind": "bot",
  "callsigns": [
    "QRX"
  ],
  "display_name": "QRX",
  "icon": "tray.full",
  "compose": {
    "intro": "Send commands as APRS messages to QRX.",
    "commands": [
      {
        "id": "reg",
        "syntax": "REG",
        "tokens": [
          "REG"
        ],
        "match": {
          "type": "prefix",
          "prefixes": [
            "REG"
          ]
        },
        "insert": "REG",
        "description": "Register your callsign for missed message monitoring."
      },
      {
        "id": "inbox",
        "syntax": "INBOX | I",
        "tokens": [
          "I",
          "INBOX"
        ],
        "match": {
          "type": "prefix",
          "prefixes": [
            "I",
            "INBOX"
          ]
        },
        "insert": "INBOX",
        "description": "Show inbox summary."
      },
      {
        "id": "read",
        "syntax": "READ | R",
        "tokens": [
          "R",
          "READ"
        ],
        "match": {
          "type": "prefix",
          "prefixes": [
            "R",
            "READ"
          ]
        },
        "insert": "READ",
        "description": "Read next missed message, newest first."
      },
      {
        "id": "who",
        "syntax": "WHO | W",
        "tokens": [
          "W",
          "WHO"
        ],
        "match": {
          "type": "prefix",
          "prefixes": [
            "W",
            "WHO"
          ]
        },
        "insert": "WHO",
        "description": "Show who sent you messages."
      },
      {
        "id": "ack",
        "syntax": "ACK | A",
        "tokens": [
          "A",
          "ACK"
        ],
        "match": {
          "type": "prefix",
          "prefixes": [
            "A",
            "ACK"
          ]
        },
        "insert": "ACK",
        "description": "Send read receipt to sender."
      },
      {
        "id": "del",
        "syntax": "DEL | D",
        "tokens": [
          "D",
          "DEL"
        ],
        "match": {
          "type": "prefix",
          "prefixes": [
            "D",
            "DEL"
          ]
        },
        "insert": "DEL",
        "description": "Delete last read message."
      },
      {
        "id": "del_all",
        "syntax": "DEL ALL | CLR",
        "tokens": [
          "CLR",
          "DEL ALL"
        ],
        "match": {
          "type": "prefix",
          "prefixes": [
            "CLR",
            "DEL ALL"
          ]
        },
        "insert": "DEL ALL",
        "description": "Clear all messages."
      },
      {
        "id": "status",
        "syntax": "STATUS | S",
        "tokens": [
          "S",
          "STATUS"
        ],
        "match": {
          "type": "prefix",
          "prefixes": [
            "S",
            "STATUS"
          ]
        },
        "insert": "STATUS",
        "description": "Check registration and inbox count."
      },
      {
        "id": "unreg",
        "syntax": "UNREG",
        "tokens": [
          "UNREG"
        ],
        "match": {
          "type": "prefix",
          "prefixes": [
            "UNREG"
          ]
        },
        "insert": "UNREG",
        "description": "Unregister and delete all data."
      },
      {
        "id": "help",
        "syntax": "HELP | H",
        "tokens": [
          "H",
          "HELP"
        ],
        "match": {
          "type": "prefix",
          "prefixes": [
            "H",
            "HELP"
          ]
        },
        "insert": "HELP",
        "description": "Help for a specific command."
      }
    ]
  },
  "description": "Missed message mailbox. Holds msgs you miss while offline.",
  "url": "https://qrx.forkum.net"
}
