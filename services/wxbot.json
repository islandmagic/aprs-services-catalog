{
  "id": "wxbot",
  "kind": "bot",
  "callsigns": [
    "WXBOT"
  ],
  "display_name": "WxBot",
  "icon": "cloud.sun",
  "compose": {
    "intro": "Ask WxBot for a forecast at your last known location, or send a city, zip, or grid square.",
    "commands": [
      {
        "id": "brief",
        "syntax": "brief",
        "tokens": [
          "brief",
          "BRIEF"
        ],
        "match": {
          "type": "prefix",
          "prefixes": [
            "brief",
            "BRIEF"
          ]
        },
        "insert": "brief",
        "description": "Short weather forecast for your location (default)."
      },
      {
        "id": "current",
        "syntax": "current",
        "tokens": [
          "current",
          "CURRENT"
        ],
        "match": {
          "type": "prefix",
          "prefixes": [
            "current",
            "CURRENT"
          ]
        },
        "insert": "current",
        "description": "Current conditions from nearest NWS station."
      },
      {
        "id": "full",
        "syntax": "full",
        "tokens": [
          "full",
          "FULL"
        ],
        "match": {
          "type": "prefix",
          "prefixes": [
            "full",
            "FULL"
          ]
        },
        "insert": "full",
        "description": "Detailed multi-message forecast."
      },
      {
        "id": "metar",
        "syntax": "metar",
        "tokens": [
          "metar",
          "METAR"
        ],
        "match": {
          "type": "prefix",
          "prefixes": [
            "metar",
            "METAR"
          ]
        },
        "insert": "metar",
        "description": "METAR report from nearest airport."
      },
      {
        "id": "city_forecast",
        "syntax": "City,ST [day] [brief|full|current|metar|cwop]",
        "tokens": [
          "brief",
          "full",
          "current",
          "metar",
          "cwop",
          "tonight",
          "tomorrow"
        ],
        "examples": [
          "Boston,MA",
          "Boston,MA Saturday full",
          "96067",
          "CN81uh",
          "KSFO metar",
          "cwop"
        ],
        "match": {
          "type": "freeform"
        },
        "insert": "Boston,MA",
        "description": "Forecast for a US city, zip, or grid square."
      },
      {
        "id": "help",
        "syntax": "help",
        "tokens": [
          "help",
          "?"
        ],
        "match": {
          "type": "prefix",
          "prefixes": [
            "help",
            "HELP",
            "?"
          ]
        },
        "insert": "help",
        "description": "Show usage information."
      }
    ]
  },
  "description": "Responds with a brief US National Weather Service forecast.",
  "url": "https://sites.google.com/site/ki6wjp/wxbot"
}
