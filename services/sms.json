{
  "id": "sms",
  "kind": "service",
  "callsigns": [
    "SMS"
  ],
  "icon": "phone.bubble",
  "compose": {
    "intro": "Send an APRS message to SMS to reach a phone number. Recipients must opt in at aprs.wiki.",
    "commands": [
      {
        "id": "send_sms",
        "syntax": "@<number> <message>",
        "tokens": [
          "@"
        ],
        "examples": [
          "@9876543210 No cell coverage. Get me on the radio!"
        ],
        "match": {
          "type": "parameterized",
          "prefixes": [
            "@"
          ],
          "parameters": [
            {
              "name": "number",
              "label": "Phone number or alias",
              "placeholder": "9876543210"
            },
            {
              "name": "message",
              "label": "Message",
              "placeholder": "Your message"
            }
          ]
        },
        "insert": "@",
        "description": "Send SMS to a phone number or alias (recipient must opt in at aprs.wiki)."
      },
      {
        "id": "alias_add",
        "syntax": "#alias #add <name> <number>",
        "tokens": [
          "#alias",
          "#ALIAS"
        ],
        "match": {
          "type": "prefix",
          "prefixes": [
            "#alias",
            "#ALIAS"
          ]
        },
        "insert": "#alias #add ",
        "description": "Save a phone number under a short name."
      },
      {
        "id": "check_missed",
        "syntax": "APRSM",
        "tokens": [
          "APRSM"
        ],
        "match": {
          "type": "prefix",
          "prefixes": [
            "APRSM"
          ]
        },
        "insert": "APRSM",
        "description": "Manually fetch missed SMS messages."
      },
      {
        "id": "delete_missed",
        "syntax": "del",
        "tokens": [
          "DEL",
          "del"
        ],
        "match": {
          "type": "prefix",
          "prefixes": [
            "del",
            "DEL"
          ]
        },
        "insert": "del",
        "description": "Clear all missed messages for your callsign."
      }
    ]
  },
  "description": "Two-way gateway between APRS and SMS (USA, Puerto Rico, Canada, Australia, UK).",
  "url": "https://aprs.wiki/"
}
