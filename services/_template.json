{
  "id": "example",
  "kind": "bot",
  "callsigns": ["EXAMPLE"],
  "display_name": "Example Bot",
  "description": "One-line description shown in the app.",
  "icon": "antenna.radiowaves.left.and.right",
  "url": "https://example.com",
  "compose": {
    "intro": "Send commands as APRS messages to EXAMPLE.",
    "commands": [
      {
        "id": "help",
        "description": "Show available commands.",
        "syntax": "HELP",
        "tokens": ["HELP", "?"],
        "match": { "type": "prefix", "prefixes": ["HELP", "?"] },
        "insert": "HELP"
      }
    ]
  }
}
